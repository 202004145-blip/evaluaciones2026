# Copia este archivo a .env y completa los valores. NUNCA subas .env al repositorio.

# Puerto donde escucha el servidor. En Railway lo inyecta la plataforma, no lo fijes.
PORT=3000

# Entorno de ejecución: development | production
# En Railway (u otro hosting) debe ser production: activa cookies seguras y trust proxy.
NODE_ENV=development

# Secreto para firmar la cookie de sesión del evaluador (OBLIGATORIO en producción).
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Ruta del archivo SQLite. Por defecto ./data.sqlite (bien para local).
# En Railway apúntalo al volumen persistente, p. ej. /data/data.sqlite
# DB_PATH=./data.sqlite

# Evaluador inicial. Si defines ambos, el servidor crea/actualiza ese usuario al
# arrancar (útil en hosting sin terminal interactiva como Railway). La contraseña
# del entorno pasa a ser la fuente de verdad en cada arranque.
# En local puedes usar en su lugar: npm run set-admin-password
# ADMIN_USER=admin
# ADMIN_PASSWORD=
