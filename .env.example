# Copia este archivo a .env y completa los valores. NUNCA subas .env al repositorio.

# Puerto donde escucha el servidor.
PORT=3000

# Entorno de ejecución: development | production
NODE_ENV=development

# Secreto para firmar la cookie de sesión del evaluador.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Ruta del archivo SQLite (opcional, por defecto ./data.sqlite).
# DB_PATH=./data.sqlite
